<keycloak-saml-adapter xmlns="urn:keycloak:saml:adapter"
                      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                      xsi:schemaLocation="urn:keycloak:saml:adapter https://www.keycloak.org/schema/keycloak_saml_adapter_1_7.xsd">
    <SP entityID="helloworld"
        sslPolicy="EXTERNAL"
        logoutPage="/logout"
        forceAuthentication="false"
        isPassive="false"
        turnOffChangeSessionIdOnLogin="false"
        autodetectBearerOnly="false">
        <Keys>
            <Key signing="true">
                <PrivateKeyPem></PrivateKeyPem>
                <CertificatePem></CertificatePem>
            </Key>
        </Keys>
        <IDP entityID="idp"
             signatureAlgorithm="RSA_SHA256"
             signatureCanonicalizationMethod="http://www.w3.org/2001/10/xml-exc-c14n#">
            <SingleSignOnService signRequest="true"
                                validateResponseSignature="true"
                                validateAssertionSignature="false"
                                requestBinding="POST"
                                bindingUrl="http://127.0.0.1:8180/auth/realms/broker_saml_test/protocol/saml"
                                assertionConsumerServiceUrl="http://127.0.0.1:8080/helloworld/saml"/>
            <SingleLogoutService validateRequestSignature="true"
                                validateResponseSignature="true"
                                signRequest="true"
                                signResponse="true"
                                requestBinding="POST"
                                responseBinding="POST"
                                postBindingUrl="http://127.0.0.1:8180/auth/realms/broker_saml_test/protocol/saml"/>
        </IDP>
    </SP>
</keycloak-saml-adapter>
